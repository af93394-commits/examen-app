# ============================================
# VARIABLES DE ENTorno - examen_app
# Copia este archivo como .env y llena los valores
# NUNCA subas el archivo .env a Git
# ============================================

# Puerto del servidor
PORT=3000

# Base de datos PostgreSQL (obtener de Render Dashboard)
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:PORT/DBNAME

# Session secret - genera una cadena aleatoria larga (minimo 32 caracteres)
# Ejemplo en Node.js: require('crypto').randomBytes(64).toString('hex')
SESSION_SECRET=TU_CLAVE_SECRETA_AQUI_CAMBIA_ESTO

# Cloudinary (obtener de https://cloudinary.com/console)
CLOUD_NAME=TU_CLOUD_NAME
CLOUD_API_KEY=TU_API_KEY
CLOUD_API_SECRET=TU_API_SECRET

# Origenes permitidos por CORS (separados por coma)
# En produccion, poner la URL de Render
ALLOWED_ORIGINS=http://localhost:3000,https://examen-app-8dto.onrender.com

# Entorno (production en Render, development en local)
NODE_ENV=production
